{
  "info": {
    "_postman_id": "f4dfdcb0-3bde-4d17-a45b-9ba8b9e5f0c1",
    "name": "SAPR Lab 9 Functional Scenario",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "Reset Workspace",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/workspace/reset",
          "host": ["{{baseUrl}}"],
          "path": ["api", "workspace", "reset"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 204', function () {",
              "    pm.response.to.have.status(204);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Source Component",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"R1\",\n  \"type\": \"RESISTOR\",\n  \"label\": \"R1\",\n  \"x\": 0,\n  \"y\": 0\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/components",
          "host": ["{{baseUrl}}"],
          "path": ["api", "components"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test('Component id is R1', function () {",
              "    pm.expect(pm.response.json().id).to.eql('R1');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Target Component",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"C1\",\n  \"type\": \"CAPACITOR\",\n  \"label\": \"C1\",\n  \"x\": 10,\n  \"y\": 0\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/components",
          "host": ["{{baseUrl}}"],
          "path": ["api", "components"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test('Component id is C1', function () {",
              "    pm.expect(pm.response.json().id).to.eql('C1');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Connection",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"W1\",\n  \"sourceComponentId\": \"R1\",\n  \"targetComponentId\": \"C1\",\n  \"signalName\": \"SIG_MAIN\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/connections",
          "host": ["{{baseUrl}}"],
          "path": ["api", "connections"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test('Connection id is W1', function () {",
              "    pm.expect(pm.response.json().id).to.eql('W1');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Summary",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/summary",
          "host": ["{{baseUrl}}"],
          "path": ["api", "summary"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Summary contains expected counters', function () {",
              "    var body = pm.response.json();",
              "    pm.expect(body.componentCount).to.eql(2);",
              "    pm.expect(body.connectionCount).to.eql(1);",
              "    pm.expect(body.isolatedComponentIds).to.eql([]);",
              "    pm.expect(body.invalidConnectionIds).to.eql([]);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
